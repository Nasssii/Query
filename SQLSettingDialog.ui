  <property name="styleSheet">
   <string notr="true">/* ================================
   QLabel 透明底优化
   放在 QSS 文件最后
   ================================ */

/* 所有 QLabel 默认透明 */
QLabel {
    background-color: transparent;
    border: none;
}

/* 左侧字段标签：host / PORT / 数据库名 / 用户名 / 密码 */
QLabel#hostlabel,
QLabel#portlabel,
QLabel#linkSQLlabel,
QLabel#SQLUserNamelabel,
QLabel#SQLPASSWORDlabel,
QLabel#LInkNamelabel {
    background-color: transparent;
    color: #526274;
    font-size: 14px;
    font-weight: 500;
    border: none;
    padding: 0px;
}

/* 三个分区标题：数据库连接 / 设置表 / 查询配置 */
QLabel#labelSQLLink,
QLabel#labelSetTable,
QLabel#labelSelSet {
    background-color: transparent;
    color: #2563EB;
    font-size: 15px;
    font-weight: 700;
    border: none;
    padding: 0px 0px 8px 0px;
}

/* 顶部大标题 SQL设置 */
QLabel#label {
    background-color: transparent;
    color: #0F172A;
    font-size: 24px;
    font-weight: 700;
    border: none;
    padding: 12px 8px 8px 14px;
}</string>
