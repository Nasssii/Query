  <property name="styleSheet">
   <string notr="true">/* -------------------------- 全局基础样式 -------------------------- */
QWidget {
    font-family: &quot;Microsoft YaHei&quot;;
    font-size: 13px;
    color: #2c3e50;
    background-color: #f5f7fa;
}

/* -------------------------- 标题栏 -------------------------- */
QFrame#frame_title {
    background-color: #d1e3f8;
    border-radius: 6px;
}

QLabel#label_title {
    font-size: 16px;
    font-weight: bold;
    color: #2d3748;
}

/* -------------------------- 标签文字 -------------------------- */
QLabel {
    color: #34495e;
}

/* -------------------------- 输入框 / 日期框 / 时间框 -------------------------- */
QLineEdit,
QDateEdit,
QTimeEdit,
QSpinBox {
    background-color: #ffffff;
    border: 1px solid #cbd5e1;
    border-radius: 4px;
    padding: 4px 8px;
    min-height: 22px;
}

QLineEdit:focus,
QDateEdit:focus,
QTimeEdit:focus {
    border: 1px solid #3b82f6;
    background-color: #eff6ff;
}

/* -------------------------- 下拉框 -------------------------- */
QComboBox {
    background-color: #ffffff;
    border: 1px solid #cbd5e1;
    border-radius: 4px;
    padding: 4px 8px;
    min-height: 22px;
}

QComboBox::drop-down {
    border: none;
}

QComboBox::down-arrow {
    image: url(:/icons/arrow_down);
    width: 10px;
    height: 10px;
}

QComboBox QAbstractItemView {
    background-color: #ffffff;
    border: 1px solid #cbd5e1;
    selection-background-color: #3b82f6;
    selection-color: #ffffff;
}

/* -------------------------- 复选框 -------------------------- */
QCheckBox {
    spacing: 6px;
}

QCheckBox::indicator {
    width: 16px;
    height: 16px;
    border: 1px solid #cbd5e1;
    border-radius: 3px;
    background-color: #ffffff;
}

QCheckBox::indicator:checked {
    background-color: #3b82f6;
    border-color: #3b82f6;
    image: url(:/icons/check);
}

/* -------------------------- 按钮（主按钮） -------------------------- */
QPushButton {
    background-color: #3b82f6;
    color: #ffffff;
    border: none;
    border-radius: 4px;
    padding: 6px 14px;
    min-height: 26px;
    font-weight: bold;
}

QPushButton:hover {
    background-color: #2563eb;
}

QPushButton:pressed {
    background-color: #1d4ed8;
}

/* -------------------------- 灰色按钮（辅助按钮） -------------------------- */
QPushButton#btn_gray {
    background-color: #64748b;
}

QPushButton#btn_gray:hover {
    background-color: #475569;
}

/* -------------------------- TabWidget 标签页 -------------------------- */
QTabWidget::pane {
    border: 1px solid #e2e8f0;
    background-color: #ffffff;
    border-radius: 6px;
    top: -1px;
}

QTabBar::tab {
    background-color: #e2e8f0;
    padding: 8px 16px;
    margin-right: 2px;
    border-top-left-radius: 4px;
    border-top-right-radius: 4px;
}

QTabBar::tab:selected {
    background-color: #ffffff;
    color: #2563eb;
    font-weight: bold;
    border-bottom: 2px solid #2563eb;
}

/* -------------------------- 表格 -------------------------- */
QTableView {
    background-color: #ffffff;
    border: 1px solid #e2e8f0;
    gridline-color: #f1f5f9;
    alternate-background-color: #f8fafc;
}

QTableView::item {
    padding: 4px;
}

QTableView::item:selected {
    background-color: #dbeafe;
    color: #1e3a8a;
}

QHeaderView::section {
    background-color: #f1f5f9;
    border: 1px solid #e2e8f0;
    padding: 6px;
    font-weight: bold;
    color: #334155;
}

/* --------------------------  滚动条 -------------------------- */
QScrollBar:vertical {
    width: 12px;
    background-color: #f8fafc;
    margin: 6px 2px 6px 2px;  /* 关键：上下左右留白，不贴边界 */
    border-radius: 6px;
}

QScrollBar::handle:vertical {
    background-color: #94a3b8;
    border-radius: 4px;
    min-height: 30px;        /* 防止滑块太扁 */
    margin: 0px 3px 0px 3px; /* 左右内边距，不贴边 */
}

QScrollBar::add-line:vertical,
QScrollBar::sub-line:vertical {
    height: 0px;
    border: none;
}

QScrollBar::handle:vertical:hover {
    background-color: #64748b;
}

/* 水平滚动条（可选，自动统一） */
QScrollBar:horizontal {
    height: 12px;
    background-color: #f8fafc;
    margin: 2px 6px 2px 6px;
    border-radius: 6px;
}

QScrollBar::handle:horizontal {
    background-color: #94a3b8;
    border-radius: 4px;
    min-width: 30px;
    margin: 3px 0px 3px 0px;
}

QScrollBar::add-line:horizontal,
QScrollBar::sub-line:horizontal {
    width: 0px;
    border: none;
}</string>
